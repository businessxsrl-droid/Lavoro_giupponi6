# Copia questo file in .env e compila i valori

# ── Supabase (database principale) ────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=eyJ...   # service_role JWT (da Supabase → Project Settings → API)

# ── JWT (generato automaticamente da Render in produzione) ────────────────────
JWT_SECRET=cambia-questo-valore-in-sviluppo

# ── OpenRouter API (salvata nel DB tramite pannello Impostazioni) ─────────────
# OPENROUTER_API_KEY non va nel .env: si configura dall'interfaccia web
