# Copia questo file in .env e compila i valori

# ── Sviluppo locale con Docker ─────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/lavoro_giupponi6

# ── Produzione (Render) ────────────────────────────────────────────────────────
# DATABASE_URL viene impostato automaticamente da Render (fromDatabase in render.yaml)

# ── Supabase (opzionale, solo se non si usa DATABASE_URL) ─────────────────────
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_KEY=sb_publishable_...

JWT_SECRET=cambia-questo-valore-in-produzione
